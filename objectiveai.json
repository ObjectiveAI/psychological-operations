{
  "owner": "ObjectiveAI",
  "name": "psychological-operations",
  "version": "0.1.0",
  "description": "Teach X's For You algorithm to surface tweets that match a function you define.",
  "exec": {
    "windows": ["./psychological-operations.exe"],
    "linux": ["./psychological-operations"],
    "macos": ["./psychological-operations"]
  },
  "cli_zip": {
    "windows": {
      "x86_64": "psychological-operations-windows-x86_64.zip",
      "aarch64": "psychological-operations-windows-aarch64.zip"
    },
    "linux": {
      "x86_64": "psychological-operations-linux-x86_64.zip",
      "aarch64": "psychological-operations-linux-aarch64.zip"
    },
    "macos": {
      "x86_64": "psychological-operations-macos-x86_64.zip",
      "aarch64": "psychological-operations-macos-aarch64.zip"
    }
  },
  "viewer_zip": "psychological-operations-viewer.zip",
  "viewer_routes": [
    { "path": "/psyops/added",   "method": "POST", "type": "psyop_added" },
    { "path": "/psyops/edited",  "method": "POST", "type": "psyop_edited" },
    { "path": "/psyops/deleted", "method": "POST", "type": "psyop_deleted" }
  ],
  "mcp_servers": [
    { "name": "x", "authorization": false }
  ]
}
