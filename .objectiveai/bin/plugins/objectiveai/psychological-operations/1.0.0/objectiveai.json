{
  "owner": "objectiveai",
  "name": "psychological-operations",
  "version": "1.0.0",
  "description": "Test build of psychological-operations — the locally-built 1.0.0 plugin the integration test suite runs through objectiveai. Teaches X's For You algorithm to surface tweets that match a function you define.",
  "exec": {
    "windows": ["./psychological-operations.exe"],
    "linux": ["./psychological-operations"],
    "macos": ["./psychological-operations"]
  },
  "cli_zip": {},
  "viewer_zip": "psychological-operations-viewer.zip",
  "viewer_routes": [
    { "path": "/psyops/added",   "method": "POST", "type": "psyop_added" },
    { "path": "/psyops/edited",  "method": "POST", "type": "psyop_edited" },
    { "path": "/psyops/deleted", "method": "POST", "type": "psyop_deleted" }
  ],
  "mcp_servers": [
    { "name": "x-api", "authorization": false }
  ]
}
